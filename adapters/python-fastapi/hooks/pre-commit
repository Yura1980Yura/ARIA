#!/usr/bin/env bash
# ARIA Adapter: python-fastapi — pre-commit hook
# SOFT warnings для форка (не блокирует)

set -e

YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

warn() { echo -e "${YELLOW}[fork pre-commit WARN]${NC} $1" >&2; }
ok()   { echo -e "${GREEN}[fork pre-commit OK]${NC} $1"; }

CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$CHANGED" ]; then
    exit 0
fi

# 1. STACK.md без CHANGELOG
if echo "$CHANGED" | grep -qE '^(project-docs/)?docs/STACK\.md$'; then
    if ! echo "$CHANGED" | grep -qE '^(project-docs/)?CHANGELOG\.md$'; then
        warn "STACK.md изменён, но CHANGELOG.md не тронут."
    fi
fi

# 2. SPEC.md без ADR
if echo "$CHANGED" | grep -qE '^(project-docs/)?docs/SPEC\.md$'; then
    if ! echo "$CHANGED" | grep -qE '^(project-docs/)?docs/ADR/ADR-'; then
        warn "SPEC.md изменён, но нет ADR."
    fi
fi

# 3. pyproject.toml зависимости — обновить STACK.md?
if echo "$CHANGED" | grep -qE 'pyproject\.toml$'; then
    warn "pyproject.toml изменён. Если добавлена новая КАТЕГОРИЯ — обнови STACK.md."
fi

# 4. Migration без spec
if echo "$CHANGED" | grep -qE '^alembic/versions/.*\.py$'; then
    if ! echo "$CHANGED" | grep -qE 'docs/spec/'; then
        warn "Миграция БД без обновления docs/spec/. Убедись что миграция задокументирована."
    fi
fi

# 5. Two-Phase Commit
CODE_FILES=$(echo "$CHANGED" | grep -vE '^project-docs/' || true)
DOCS_FILES=$(echo "$CHANGED" | grep -E '^project-docs/' || true)

if [ -n "$CODE_FILES" ] && [ -n "$DOCS_FILES" ]; then
    warn "КОД и DOCS в одном коммите! Two-Phase Commit нарушен."
fi

ok "Fork pre-commit (python-fastapi) — soft checks завершены"
exit 0
